""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""
" Keys on Nuphy Keyboard (MAC)
"   S - Shift
"   C - CTRL
"   A - OPT
"   M - Cmd
"
" Navigate Tabs Vim bindings:
"   gt, go to next tab
"   gT, go to the previous tab
"   1gt, go to the first tab
"   2gt, go to the second tab
"   3gt, ....
"
" Plugin Commentary:
"   gc{motion}     Comment or uncomment lines that {motion} moves over.
"   gcc            Comment or uncomment [count] lines.
"   {Visual}gc     Comment or uncomment the highlighted lines.
"   gc             Text object for a comment (operator pending mode only.)
"   gcgc           Uncomment the current and adjacent commented lines.
"   gcu
"
" IntelliJ Code Completion:
"   Shortcut: Shift + Opt + Space
"   Configuration: Settings | Editor | General | Code Completion | Show suggestions as you type | Popup
" 
" IntelliJ Shortcuts:
"    Ctrl-TAB                           -     Switcher
"    Cmd-1                              -     Focus Project Explorer
"    <space> focus Project Explorer     -     show File Preview
""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""""

set scrolloff=5
set history=1000

" Plugins
set surround
set NERDTree
set which-key
set easymotion
set commentary
set highlightedyank

" which-key: increase the timeoutlen (default: 1000), don't add space around the equal sign
set notimeout

let g:WhichKey_FontSize = 15
let g:WhichKey_PrefixColor = "#f5a97f"
let g:WhichKey_CommandColor = "#7dc4e4"
let g:WhichKey_PrefixStyle = "bold"
let g:WhichKey_KeyStyle = "italic"
let g:WhichKey_SortOrder = "by_key_prefix_first"
let g:WhichKey_ShowTypedSequence = "true"
let g:WhichKey_ShowVimActions = "true"

let g:WhichKeyDesc_easymotion = "<leader><leader> EasyMotion"

" highlightedyank: highlight yanked text for 2000ms (default: 500)
let g:highlightedyank_highlight_duration = "2000"
let g:highlightedyank_highlight_color = "rgba(147, 154, 183, 100)"

" leader key
let mapleader = ' '
let g:WhichKeyDesc_leader = "<leader> Leader Key"

" sync Vim clipboard with OS clipboard
set clipboard^=unnamed,unnamedplus

" jump between angle brackets
set matchpairs+=<:>

" smart line joining
set ideajoin

let g:WhichKeyDesc_vim_config = "<leader>c Vim Configuration"
" open config
noremap <leader>cc :edit ~/.ideavimrc<cr>
let g:WhichKeyDesc_vim_config_edit = "<leader>cc Edit Vim Configuration File"
" source config
noremap <leader>cs :source ~/.ideavimrc<cr>:nohlsearch<cr>
let g:WhichKeyDesc_vim_config_reload = "<leader>cs Reload Vim Configuration File"

set hlsearch
" remove search highlights
nnoremap <Esc> :nohlsearch<cr>
" case-insensitive search
set ignorecase
" enable case-sensitive search when uppercased letter is present
set smartcase
" search while typing
set incsearch

""" Distraction Free Mode
nnoremap <C-z> :action ToggleDistractionFreeMode<CR>
map <leader>Dz <action>(ToggleZenMode)
map <leader>Df <action>(ToggleFullScreen)
let g:WhichKeyDesc_display = "<Leader>D Display options"
let g:WhichKeyDesc_zen_mode = "<Leader>Dz Toggle Zen mode"
let g:WhichKeyDesc_fullscreen = "<Leader>Df Toggle full screen"

""" Terminal
nnoremap <C-t> :action ActivateTerminalToolWindow<CR>

""" Navigation

nnoremap <C-\> :action SplitVertically<CR>
nnoremap <C--> :action SplitHorizontally<CR>
nnoremap <C-=> :action Unsplit<CR>
nnoremap <C-m> :action MoveEditorToOppositeTabGroup<CR>

sethandler <C-j> a:vim
sethandler <C-k> a:vim

" go to the left split
nnoremap <C-h> <C-w>h
" go to the bottom split
nnoremap <C-k> <C-w>j
" go to the top split
nnoremap <C-j> <C-w>k
" go to the right split
nnoremap <C-l> <C-w>l

" switch to next tab
nnoremap <TAB> gt
" switch to previous tab
nnoremap <S-TAB> gT

nnoremap <Leader>en :action EditSourceInNewWindow<CR>
nnoremap <Leader>n :action NextWindow<CR>
let g:WhichKeyDesc_editor = "<Leader>e Editor"
let g:WhichKeyDesc_editor_new_window = "<Leader>en Open in new Window"
let g:WhichKeyDesc_next_window = "<Leader>n Next Window"

nnoremap <Leader>qc :action CloseContent<CR>
nnoremap <Leader>qa :action CloseAllEditors<CR>
let g:WhichKeyDesc_tabs = "<Leader>q Tabs"
let g:WhichKeyDesc_tabs_close_current = "<Leader>qc Close Current Tab"
let g:WhichKeyDesc_tabs_close_all = "<Leader>qa Close All Tabs"

""" Editor source code

vnoremap < <gv
vnoremap > >gv

nnoremap [[ :action MethodUp<CR>
nnoremap ]] :action MethodDown<CR>

nnoremap zc :action CollapseRegion<CR>
nnoremap zo :action ExpandRegion<CR>
nnoremap <Leader>zc :action CollapseAllRegions<CR>
nnoremap <Leader>zo :action ExpandAllRegions<CR>
let g:WhichKeyDesc_regions = "<Leader>z Regions"
let g:WhichKeyDesc_regions_collapse_all = "<Leader>zc Collapse All Regions"
let g:WhichKeyDesc_regions_expand_all = "<Leader>zo Expand All Regions"

nnoremap <Leader>ln :action RenameElement<CR>
nnoremap <Leader>lm :action ExtractMethod<CR>
nnoremap <Leader>lv :action IntroduceVariable<CR>
nnoremap <Leader>lf :action IntroduceField<CR>
nnoremap <Leader>ls :action ChangeSignature<CR>
nnoremap <Leader>lr :action Refactorings.QuickListPopupAction<CR>
let g:WhichKeyDesc_language = "<Leader>l Language"
let g:WhichKeyDesc_language_rename = "<Leader>ln Rename Element"
let g:WhichKeyDesc_language_extract = "<Leader>lm Extract Method"
let g:WhichKeyDesc_language_variable = "<Leader>lv Introduce Variable"
let g:WhichKeyDesc_language_field = "<Leader>lf Introduce Field"
let g:WhichKeyDesc_language_change_signature = "<Leader>ls Change Signature"
let g:WhichKeyDesc_language_quick_list_popup = "<Leader>lr Quick List Popup"

nnoremap <Leader>= :action ReformatCode<CR>
nnoremap <Leader>o :action OptimizeImports<CR>
let g:WhichKeyDesc_reformat_code = "<Leader>= Reformat Code"
let g:WhichKeyDesc_organize_imports = "<Leader>o Organize Imports"

sethandler <C-r> a:vim

nnoremap <C-r> :action RecentFiles<CR>
nnoremap <Leader>r :action RecentLocations<CR>
nnoremap <Leader>h :action LocalHistory.ShowHistory<CR>
let g:WhichKeyDesc_recent_locations = "<Leader>r Recent Locations"
let g:WhichKeyDesc_show_local_history = "<Leader>h Show Local History"

nnoremap <Leader>ge :action GotoNextError<CR>
nnoremap <Leader>gE :action GotoPreviousError<CR>
let g:WhichKeyDesc_goto = "<Leader>g Goto"
let g:WhichKeyDesc_goto_next = "<Leader>ge Goto Next Error"
let g:WhichKeyDesc_goto_previous = "<Leader>gE Goto Previous Error"

imap <A-space> <Action>(CodeCompletion)

""" Searching and Source Code Navigation

sethandler <M-/> a:vim

nnoremap <M-/> :action FindInPath<CR>
nnoremap <M-a> :action GotoAction<CR>
nnoremap <M-f> :action GotoFile<CR>

nnoremap <Leader>s :action GotoRelated<CR>
nnoremap <Leader>y :action CallHierarchy<CR>
nnoremap <Leader>u :action FindUsages<CR>
let g:WhichKeyDesc_goto_related = "<Leader>s Goto Related"
let g:WhichKeyDesc_call_hierarchy = "<Leader>y Call Hierarchy"
let g:WhichKeyDesc_find_usages = "<Leader>u Find Usages"

nnoremap <M-s> :action FileStructurePopup<CR>

nnoremap <Leader>gc :action GotoClass<CR>
nnoremap <Leader>gd :action GotoDeclaration<CR>
nnoremap <Leader>gD :action GotoTypeDeclaration<CR>
nnoremap <Leader>gi :action GotoImplementation<CR>
nnoremap <Leader>gt :action GotoTest<CR>
nnoremap <Leader>gm :action GotoSuperMethod<CR>
nnoremap <Leader>gs :action GotoSymbol<CR>
let g:WhichKeyDesc_goto_class = "<Leader>gc Goto Class"
let g:WhichKeyDesc_goto_declaration = "<Leader>gd Goto Declaration"
let g:WhichKeyDesc_goto_type_declaration = "<Leader>gD Goto Type-Declaration"
let g:WhichKeyDesc_goto_implementation = "<Leader>gi Goto Implementation"
let g:WhichKeyDesc_goto_test = "<Leader>gt Goto Test"
let g:WhichKeyDesc_goto_super_method = "<Leader>gm Goto Super-Method"
let g:WhichKeyDesc_goto_symbol = "<Leader>gs Goto Symbol"

nnoremap <Leader>iu :action ShowUsages<CR>
nnoremap <leader>iU :action ShowUmlDiagram<CR>
nnoremap <Leader>ie :action ShowErrorDescription<CR>
nnoremap <Leader>ii :action QuickImplementations<CR>
nnoremap <Leader>it :action QuickTypeDefinition<CR>
nnoremap <Leader>ie :action ExpressionTypeInfo<CR>
nnoremap <leader>ip :action ParameterInfo<CR>
nnoremap <leader>ij :action QuickJavaDoc<CR>
nnoremap <leader>im :action MethodHierarchy<CR>
let g:WhichKeyDesc_info = "<Leader>i Information"
let g:WhichKeyDesc_info_usages = "<Leader>iu Show Usages"
let g:WhichKeyDesc_info_uml_diagram = "<Leader>iU UML Diagram"
let g:WhichKeyDesc_info_error_description = "<Leader>ie Show Error Description"
let g:WhichKeyDesc_info_quick_implementations = "<Leader>ii Quick Implementations"
let g:WhichKeyDesc_info_quick_type_definitions = "<Leader>it Quick Type Definitions"
let g:WhichKeyDesc_info_expressions_type_info = "<Leader>ie Expressions Type Info"
let g:WhichKeyDesc_info_parameter = "<Leader>ip Parameter Info"
let g:WhichKeyDesc_info_javadoc = "<Leader>ij Java Doc"
let g:WhichKeyDesc_info_method_hierarchy = "<Leader>im Method Hierarchy"

""" Tool Windows

sethandler <C-p> a:vim

nnoremap <C-p> :action JumpToLastWindow<CR>
nnoremap <C-x> :action HideAllWindows<CR>

nnoremap <Leader>wt :action ActivateTerminalToolWindow<CR>
nnoremap <Leader>wa :action ActivateDatabaseToolWindow<CR>
nnoremap <Leader>wb :action ActivateBuildToolWindow<CR>
nnoremap <Leader>wp :action ActivateProjectToolWindow<CR>
nnoremap <Leader>wd :action ActivateDebugToolWindow<CR>
nnoremap <Leader>we :action ActivateRunToolWindow<CR>
nnoremap <Leader>ws :action ActivateStructureToolWindow<CR>
nnoremap <Leader>wc :action ActivateCommitToolWindow<CR>
