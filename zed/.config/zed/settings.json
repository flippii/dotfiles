// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
// Move all panel to the right
{
	"cli_default_open_behavior": "existing_window",
	"edit_predictions": {
		"provider": "zed",
	},
	"agent_servers": {
		"github-copilot": {
			"type": "registry",
		},
		"opencode": {
			"type": "registry",
		},
	},
	"agent_ui_font_size": 16.0,
	"agent_buffer_font_size": 14.0,
	"context_servers": {
		"mcp-server-context7": {
   "enabled": true,
			"settings": {
				"context7_api_key": "ctx7sk-553a5119-7201-464c-b482-463422847b10",
			},
		},
	},
	"session": {
		"trust_all_worktrees": true,
	},
	"status_bar": {
		"experimental.show": true,
	},
	"cursor_shape": "bar",
	"cursor_blink": true,
	"use_system_window_tabs": true,
	"gutter": {
		"line_numbers": true,
	},
	"show_whitespaces": "all",
	"show_edit_predictions": true,
	"hard_tabs": true,
	"autosave": "on_focus_change",
	"ui_font_family": "Hack Nerd Font Mono",
	"git_panel": {
		"sort_by_path": true,
		"tree_view": true,
		"dock": "right",
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Catppuccin Mocha",
		"dark": "Catppuccin Mocha",
	},
	// Edit prediction provider (moved from deprecated features.edit_prediction_provider)
	"base_keymap": "VSCode",
	"theme": {
		"mode": "dark",
		"light": "Catppuccin Latte",
		"dark": "Catppuccin Macchiato",
	},
	"ui_font_size": 16,
	"buffer_font_size": 14.0,
	// NOTE: Change the font family to your preference
	"buffer_font_family": "Hack Nerd Font Mono",
	// Vim mode settings
	"vim_mode": true,
	"vim": {
		"use_system_clipboard": "on_yank",
		"use_smartcase_find": true,
		"toggle_relative_line_numbers": true,
		"highlight_on_yank_duration": 1000,
	},
	"which_key": {
		"delay_ms": 500,
		"enabled": true,
	},
	// use relative line numbers (fallback, vim.toggle_relative_line_numbers handles this dynamically)
	"relative_line_numbers": "enabled",
	"tab_bar": {
		"show": true,
	},
	"scrollbar": {
		"show": "never",
	},
	// Only show error on tab
	"tabs": {
		"show_diagnostics": "errors",
	},
	// Indentation, rainbow indentation
	"indent_guides": {
		"enabled": true,
		"coloring": "indent_aware",
	},
	// NOTE: Zen mode, refer https://github.com/zed-industries/zed/issues/4382 when it's resolved
	"centered_layout": {
		"left_padding": 0.15,
		"right_padding": 0.15,
	},
	"agent": {
		"dock": "left",
		"tool_permissions": {
			"tools": {
				"terminal": {
					"always_allow": [
						{
							"pattern": "^find\\s+\\~/\\.config/zed(\\s|$)",
						},
						{
							"pattern": "^cat\\s+\\~/\\.config/zed/settings\\.json(\\s|$)",
						},
					],
				},
				"fetch": {
					"default": "allow",
				},
			},
		},
		"default_view": "text_thread",
		"play_sound_when_agent_done": "always",
		"single_file_review": false,
		"expand_edit_card": true,
		"expand_terminal_card": true,
		"enable_feedback": true,
		"profiles": {
			"write": {
				"name": "Write",
				"tools": {
					"search_web": true,
					"open": true,
					"create_directory": true,
					"terminal": true,
					"batch_tool": true,
					"code_actions": true,
					"code_symbols": true,
					"contents": true,
					"copy_path": true,
					"create_file": true,
					"delete_path": true,
					"diagnostics": true,
					"edit_file": true,
					"fetch": true,
					"list_directory": true,
					"move_path": true,
					"now": true,
					"find_path": true,
					"read_file": true,
					"grep": true,
					"rename": true,
					"symbol_info": true,
					"thinking": true,
				},
				"enable_all_context_servers": true,
				"context_servers": {},
			},
		},
		"default_profile": "write",
		"default_model": {
			"effort": "xhigh",
			"enable_thinking": true,
			"provider": "zed.dev",
			"model": "gpt-5.5",
		},
		"inline_assistant_model": {
			"provider": "zed.dev",
			"model": "claude-sonnet-4-thinking",
		},
		"commit_message_model": {
			"provider": "zed.dev",
			"model": "claude-sonnet-4-thinking",
		},
	},
	// To use Ollama, configure language_models.ollama below and set agent.default_model
	// Refer: https://zed.dev/docs/ai/llm-providers
	"language_models": {
		"opencode": {
			"show_go_models": false,
			"show_zen_models": false,
		},
		"ollama": {
			"api_url": "http://localhost:11434",
			"auto_discover": true,
		},
	},
	// Diagnostics settings
	"diagnostics": {
		"include_warnings": true,
	},
	// Git inline blame
	"git": {
		"inline_blame": {
			"enabled": true,
		},
	},
	// Inlay hints preconfigured by Zed: Go, Rust, Typescript and Svelte
	"inlay_hints": {
		"enabled": false,
	},
	// LSP
	"lsp": {
		"basedpyright": {
			"settings": {
				"python": {
					"pythonPath": ".venv/bin/python",
				},
			},
		},
		"ruff": {
			"initialization_options": {
				"settings": {
					"configuration": "ruff.toml",
				},
			},
		},
	},
	"languages": {
		"Python": {
			"formatter": "language_server",
			"language_servers": ["pyright", "ruff"],
		},
	},
	// Use zed commit editor
	"terminal": {
		"font_size": 14.0,
		"font_family": "Hack Nerd Font Mono",
		"env": {
			"EDITOR": "zed --wait",
		},
	},
	// File syntax highlighting
	"file_types": {
		"Dockerfile": ["Dockerfile", "Dockerfile.*"],
		"JSON": ["json", "jsonc", "*.code-snippets"],
	},
	// File scan exclusions, hide on the file explorer and search
	"file_scan_exclusions": [
		"**/.git",
		"**/.svn",
		"**/.hg",
		"**/CVS",
		"**/.DS_Store",
		"**/Thumbs.db",
		"**/.classpath",
		"**/.settings",
		// above is default from Zed
		"**/out",
		"**/dist",
		"**/.husky",
		"**/.turbo",
		"**/.vscode-test",
		"**/.vscode",
		"**/.next",
		"**/.storybook",
		"**/.tap",
		"**/.nyc_output",
		"**/report",
		"**/node_modules",
	],
	// Turn off telemetry
	"telemetry": {
		"diagnostics": false,
		"metrics": false,
	},
	// Move all panel to the right
	"project_panel": {
		"auto_fold_dirs": false,
		"button": true,
		"dock": "left",
		"git_status": true,
	},
	"outline_panel": {
		"dock": "right",
	},
	"collaboration_panel": {
		"dock": "right",
	},
	// Move some unnecessary panels to the left
	"notification_panel": {
		"dock": "left",
	},
}
